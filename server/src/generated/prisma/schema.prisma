generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                @id @default(uuid())
  email         String                @unique
  name          String?
  avatarUrl     String?
  password      String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  memberships   Membership[]
  messagesSent  Message[]             @relation("message_sender")
  notifications Notification[]
  notifSettings NotificationSetting[]
  refreshTokens RefreshToken[]
  templates     Template[]

  @@index([email])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revoked   Boolean   @default(false)
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Workspace {
  id               String                @id @default(uuid())
  name             String
  slug             String                @unique
  logoUrl          String?
  timezone         String                @default("UTC")
  currency         String                @default("USD")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  apiKeys          ApiKey[]
  assignmentRule   AssignmentRule?
  auditLogs        AuditLog[]
  campaigns        Campaign[]
  chatbots         Chatbot[]
  contacts         Contact[]
  contactGroups    ContactGroup[]
  conversations    Conversation[]
  invites          Invite[]
  memberships      Membership[]
  messages         Message[]
  notifSettings    NotificationSetting[]
  subscriptions    Subscription[]
  tags             Tag[]
  templates        Template[]
  usages           Usage[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents    WebhookEvent[]
  whatsappAccounts WhatsAppAccount[]

  @@index([slug])
  @@index([createdAt])
}

model Invite {
  id          String       @id @default(uuid())
  email       String
  token       String       @unique
  workspaceId String
  role        Role
  status      InviteStatus @default(PENDING)
  invitedBy   String?
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([token])
  @@index([email])
}

model Membership {
  id                    String           @id @default(uuid())
  userId                String
  workspaceId           String
  role                  Role             @default(AGENT)
  isActive              Boolean          @default(true)
  joinedAt              DateTime         @default(now())
  lastSeenAt            DateTime?
  maxConcurrentChats    Int?
  isAvailable           Boolean          @default(true)
  notifyOnAssignment    Boolean          @default(true)
  notifyOnMention       Boolean          @default(true)
  fallbackAgent         AssignmentRule[] @relation("assignment_fallback")
  assignmentRules       AssignmentRule[]
  assignedConversations Conversation[]   @relation("conversation_assignee")
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace             Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
  @@index([workspaceId, isActive])
}

model Plan {
  id              String         @id @default(uuid())
  slug            String         @unique
  name            String
  description     String?
  priceCents      Int
  currency        String         @default("USD")
  billingInterval String         @default("monthly")
  isPublic        Boolean        @default(true)
  isActive        Boolean        @default(true)
  trialDays       Int            @default(0)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  featureLimits   FeatureLimit[]
  subscriptions   Subscription[]

  @@index([slug])
  @@index([isPublic, isActive])
}

model FeatureLimit {
  id         String     @id @default(uuid())
  planId     String
  key        FeatureKey
  limitValue Int?
  note       String?
  plan       Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@index([key])
}

model Subscription {
  id                     String        @id @default(uuid())
  workspaceId            String
  planId                 String
  status                 BillingStatus @default(TRIAL)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean       @default(false)
  cancelledAt            DateTime?
  trialEndsAt            DateTime?
  externalCustomerId     String?
  externalSubscriptionId String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  plan                   Plan          @relation(fields: [planId], references: [id])
  workspace              Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
  @@index([externalSubscriptionId])
}

model Usage {
  id          String     @id @default(uuid())
  workspaceId String
  key         FeatureKey
  periodStart DateTime
  periodEnd   DateTime
  count       Int        @default(0)
  meta        Json?
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key, periodStart])
  @@index([workspaceId, key])
  @@index([periodStart, periodEnd])
}

model WhatsAppAccount {
  id              String         @id @default(uuid())
  workspaceId     String
  provider        Provider       @default(WHATSAPP_CLOUD)
  phoneNumber     String
  phoneNumberId   String?
  wabaId          String?
  displayName     String?
  credentials     Json?
  webhookVerified Boolean        @default(false)
  status          String         @default("pending")
  statusReason    String?
  connectedAt     DateTime?
  disconnectedAt  DateTime?
  qualityRating   String?
  messagingLimit  String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations   Conversation[]
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId, provider])
  @@index([workspaceId, status])
}

model Contact {
  id               String               @id @default(uuid())
  workspaceId      String
  name             String?
  phoneNumber      String
  email            String?
  avatarUrl        String?
  externalId       String?
  isOptOut         Boolean              @default(false)
  optOutAt         DateTime?
  lastSeenAt       DateTime?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  campaignContacts CampaignContact[]
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  groupMemberships ContactGroupMember[]
  conversations    Conversation[]

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId, phoneNumber])
  @@index([workspaceId, isOptOut])
  @@index([workspaceId, lastSeenAt])
}

model ContactGroup {
  id          String               @id @default(uuid())
  workspaceId String
  name        String
  description String?
  color       String?
  isSystem    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  campaigns   Campaign[]
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     ContactGroupMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ContactGroupMember {
  id        String       @id @default(uuid())
  contactId String
  groupId   String
  addedAt   DateTime     @default(now())
  addedBy   String?
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
  @@index([groupId])
  @@index([contactId])
}

model Tag {
  id            String            @id @default(uuid())
  workspaceId   String
  name          String
  color         String?
  createdAt     DateTime          @default(now())
  conversations ConversationTag[]
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ConversationTag {
  conversationId String
  tagId          String
  addedAt        DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@index([tagId])
}

model Conversation {
  id                String             @id @default(uuid())
  workspaceId       String
  whatsappAccountId String
  contactId         String?
  status            ConversationStatus @default(OPEN)
  assigneeId        String?
  chatbotId         String?
  isBotActive       Boolean            @default(false)
  unreadCount       Int                @default(0)
  lastMessageAt     DateTime?
  lastInboundAt     DateTime?
  resolvedAt        DateTime?
  firstResponseAt   DateTime?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  sessions          ChatbotSession[]
  assignee          Membership?        @relation("conversation_assignee", fields: [assigneeId], references: [id])
  chatbot           Chatbot?           @relation(fields: [chatbotId], references: [id])
  contact           Contact?           @relation(fields: [contactId], references: [id])
  whatsappAccount   WhatsAppAccount    @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags              ConversationTag[]
  messages          Message[]

  @@index([workspaceId, status])
  @@index([workspaceId, whatsappAccountId])
  @@index([workspaceId, contactId])
  @@index([workspaceId, assigneeId])
  @@index([assigneeId])
  @@index([lastMessageAt])
  @@index([chatbotId, isBotActive])
}

model Message {
  id                String           @id @default(uuid())
  conversationId    String
  workspaceId       String
  senderId          String?
  direction         MessageDirection
  type              String           @default("text")
  status            MessageStatus    @default(PENDING)
  text              String?
  payload           Json?
  providerMessageId String?
  metadata          Json?
  isDeleted         Boolean          @default(false)
  createdAt         DateTime         @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  error             String?
  attachments       Attachment[]
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User?            @relation("message_sender", fields: [senderId], references: [id])
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([workspaceId, providerMessageId])
  @@index([workspaceId, direction, status])
  @@index([senderId])
  @@index([workspaceId, type])
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  url       String
  mediaId   String?
  filename  String?
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  duration  Int?
  caption   String?
  meta      Json?
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model AssignmentRule {
  id              String             @id @default(uuid())
  workspaceId     String             @unique
  strategy        AssignmentStrategy @default(ROUND_ROBIN)
  allowedRoles    Role[]
  fallbackAgentId String?
  active          Boolean            @default(true)
  lastIndex       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  membershipId    String?
  fallbackAgent   Membership?        @relation("assignment_fallback", fields: [fallbackAgentId], references: [id])
  membership      Membership?        @relation(fields: [membershipId], references: [id])
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Template {
  id                 String         @id @default(uuid())
  workspaceId        String
  name               String
  language           String         @default("en_US")
  category           String
  type               TemplateType   @default(TEXT)
  components         Json
  variables          Json?
  status             TemplateStatus @default(PENDING)
  rejectionReason    String?
  providerTemplateId String?        @unique
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  campaigns          Campaign[]
  createdBy          User?          @relation(fields: [createdById], references: [id])
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name, language])
  @@index([workspaceId, status])
}

model Campaign {
  id              String            @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  status          CampaignStatus    @default(DRAFT)
  templateId      String?
  audienceGroupId String?
  audienceFilter  Json?
  settings        Json?
  scheduledAt     DateTime?
  timezone        String?
  totalRecipients Int               @default(0)
  sentCount       Int               @default(0)
  deliveredCount  Int               @default(0)
  readCount       Int               @default(0)
  failedCount     Int               @default(0)
  optedOutCount   Int               @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  audienceGroup   ContactGroup?     @relation(fields: [audienceGroupId], references: [id])
  template        Template?         @relation(fields: [templateId], references: [id])
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts        CampaignContact[]

  @@index([workspaceId, status])
  @@index([scheduledAt])
}

model CampaignContact {
  id                String                @id @default(uuid())
  campaignId        String
  contactId         String
  status            CampaignContactStatus @default(PENDING)
  providerMessageId String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  error             String?
  retryCount        Int                   @default(0)
  resolvedVariables Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  campaign          Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact           Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([status, failedAt])
}

model Chatbot {
  id              String           @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  isActive        Boolean          @default(false)
  config          Json?
  triggerKeywords String[]
  triggerOnNew    Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes           ChatbotNode[]
  sessions        ChatbotSession[]
  conversations   Conversation[]

  @@index([workspaceId, isActive])
}

model ChatbotNode {
  id        String   @id @default(uuid())
  botId     String
  key       String
  type      String
  config    Json?
  next      Json?
  position  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bot       Chatbot  @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, key])
  @@index([botId])
}

model ChatbotSession {
  id             String                @id @default(uuid())
  chatbotId      String
  conversationId String
  currentNodeKey String?
  state          Json?
  turnCount      Int                   @default(0)
  isActive       Boolean               @default(true)
  handedOffAt    DateTime?
  handoffReason  ChatbotHandoffReason?
  handoffAgentId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  chatbot        Chatbot               @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation   Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, isActive])
  @@index([chatbotId])
}

model Notification {
  id             String              @id @default(uuid())
  userId         String
  type           NotificationType
  channel        NotificationChannel @default(IN_APP)
  title          String
  body           String?
  workspaceId    String?
  conversationId String?
  campaignId     String?
  messageId      String?
  isRead         Boolean             @default(false)
  readAt         DateTime?
  createdAt      DateTime            @default(now())
  deliveredAt    DateTime?
  failedAt       DateTime?
  error          String?
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

model NotificationSetting {
  id          String              @id @default(uuid())
  userId      String
  workspaceId String?
  type        NotificationType
  channel     NotificationChannel
  enabled     Boolean             @default(true)
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, type, channel])
  @@index([userId, workspaceId])
}

model WebhookEndpoint {
  id          String            @id @default(uuid())
  workspaceId String
  url         String
  description String?
  secret      String
  isActive    Boolean           @default(true)
  events      String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  WebhookDelivery[]
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
}

model WebhookDelivery {
  id            String                @id @default(uuid())
  endpointId    String
  eventType     String
  payload       Json
  status        WebhookDeliveryStatus @default(PENDING)
  httpStatus    Int?
  responseBody  String?
  attemptCount  Int                   @default(0)
  nextRetryAt   DateTime?
  lastAttemptAt DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  endpoint      WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  workspaceId String
  provider    Provider
  eventType   String?
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  status      String    @default("pending")
  error       String?
  retryCount  Int       @default(0)
  nextRetryAt DateTime?
  meta        Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, status])
  @@index([receivedAt])
  @@index([status, nextRetryAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  isActive    Boolean   @default(true)
  createdById String?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@index([keyHash])
}

model AuditLog {
  id          String     @id @default(uuid())
  workspaceId String?
  userId      String?
  action      String
  resource    String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId])
  @@index([action])
}

enum Role {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum TemplateType {
  TEXT
  MEDIA
  BUTTON
  REPLY
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignContactStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  OPTED_OUT
}

enum Provider {
  WHATSAPP_CLOUD
  WHATSAPP_BUSINESS_API
  OTHER
}

enum BillingStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIAL
  EXPIRED
}

enum FeatureKey {
  MESSAGES_PER_MONTH
  WHATSAPP_ACCOUNTS
  AI_CHATBOT
  AUTOMATION_LEVEL
  SUPPORT_LEVEL
  MESSAGE_TEMPLATES
  ANALYTICS_LEVEL
  CRM_INTEGRATIONS
  TEAM_MEMBERS
  CUSTOM_BRANDING
  API_ACCESS
  WORKSPACES
}

enum NotificationType {
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_RESOLVED
  CAMPAIGN_COMPLETED
  CAMPAIGN_FAILED
  AGENT_JOINED
  AGENT_LEFT
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  WEBHOOK_FAILED
  CHATBOT_HANDOFF
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WEBHOOK
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ChatbotHandoffReason {
  USER_REQUESTED
  NO_MATCH
  MAX_TURNS_REACHED
  AGENT_TRIGGERED
  ERROR
}

enum AssignmentStrategy {
  ROUND_ROBIN
  LOAD_BALANCE
  LEAST_ACTIVE
}
